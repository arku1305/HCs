const tagClass = { c1: 'tag-c1', c2: 'tag-c2', c3: 'tag-c3', c4: 'tag-c4' };

function buildGrid(containerId, data, colorKey) {
  const container = document.getElementById(containerId);
  if (!container) return;
  data.forEach(hc => {
    const card = document.createElement('div');
    card.className = 'hc-card';
    card.innerHTML = `
      <div class="hc-header">
        <span class="hc-tag ${tagClass[colorKey]}">${hc.tag}</span>
        <div>
          <div class="hc-title">${hc.title}</div>
          <div class="hc-subtitle">${hc.subtitle}</div>
        </div>
      </div>
      <div class="hc-details">
        <div class="detail-row">
          <i class="ti ti-bulb detail-icon" aria-hidden="true"></i>
          <div class="detail-text"><strong>定義：</strong>${hc.def}</div>
        </div>
        <div class="detail-row">
          <i class="ti ti-repeat detail-icon" aria-hidden="true"></i>
          <div class="detail-text"><strong>每日練習：</strong>${hc.practice}</div>
        </div>
        <div class="detail-row">
          <i class="ti ti-map-pin detail-icon" aria-hidden="true"></i>
          <div class="detail-text"><strong>真實案例：</strong>${hc.example}</div>
        </div>
        <div class="detail-row">
          <i class="ti ti-tag detail-icon" aria-hidden="true"></i>
          <div class="detail-text" style="color: var(--color-text-tertiary);">類型：${hc.type === 'H' ? 'H（習慣）' : 'C（概念）'}</div>
        </div>
      </div>
    `;
    card.addEventListener('click', () => {
      const wasExpanded = card.classList.contains('expanded');
      card.classList.toggle('expanded', !wasExpanded);
    });
    container.appendChild(card);
  });
}

function buildDayPlan() {
  const container = document.getElementById('day-plan-container');
  PLAN.forEach(item => {
    const div = document.createElement('div');
    div.className = 'day-item';
    div.innerHTML = `
      <div class="day-num">${item.day}</div>
      <div class="day-content">
        <div class="day-tag">${item.cat} · ${item.tag}</div>
        <div class="day-title">${item.title}</div>
        <div class="day-desc">${item.desc}</div>
      </div>
    `;
    container.appendChild(div);
  });
}

function switchTab(id) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  const el = document.getElementById('tab-' + id);
  if (el) el.classList.add('active');
  const btns = document.querySelectorAll('.tab-btn');
  const tabNames = ['overview','c1','c2','c3','c4','plan'];
  const idx = tabNames.indexOf(id);
  if (idx >= 0 && btns[idx]) btns[idx].classList.add('active');
}

